{
  "name": "luka",
  "version": "0.1.0",
  "description": "Minimal coding agent built with TypeScript and an OpenAI-compatible (Volcengine Ark) API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "luka": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/demo.cast",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm test",
    "dev": "tsc --watch",
    "docs:build": "rspress build",
    "docs:dev": "rspress dev",
    "docs:preview": "rspress preview",
    "eval": "npm run build && node dist/evals/runner.js",
    "eval:mock": "npm run build && node dist/evals/runner.js --suite smoke --mock",
    "eval:regression": "npm run build && node dist/evals/runner.js --suite regression --repeat 3 --baseline evals/baselines/p4-continuous.json --check",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "ink": "^7.0.6",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@rspress/core": "^2.0.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "ink-testing-library": "^4.0.0",
    "rspress-plugin-mermaid": "^1.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
