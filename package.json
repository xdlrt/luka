{
  "name": "coding-agent",
  "version": "0.1.0",
  "description": "Minimal coding agent built with TypeScript and an OpenAI-compatible (Volcengine Ark) API",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coding-agent": "dist/index.js"
  },
  "files": [
    "dist",
    "docs/demo.cast",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm test",
    "dev": "tsc --watch",
    "eval": "npm run build && node dist/evals/runner.js",
    "eval:mock": "npm run build && node dist/evals/runner.js --suite smoke --mock",
    "start": "npm run build && node dist/index.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
